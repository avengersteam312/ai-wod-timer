# API Configuration
API_V1_PREFIX=/api/v1
PROJECT_NAME=AI Workout Timer
DEBUG=True

# AI Service
OPENAI_API_KEY=your_openai_api_key_here

# AI Model Selection
AI_PROVIDER=openai
AI_MODEL=gpt-4o-mini

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_workout
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_workout_test

# Redis
REDIS_URL=redis://localhost:6379/0

# CORS
BACKEND_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Supabase Configuration (backend must use JWT anon key for /auth/v1/user)
# Get keys via Supabase MCP get_publishable_keys or Dashboard > Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...  # Legacy JWT anon key (required for token verification)
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here
