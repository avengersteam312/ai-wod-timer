{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.4.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "AI WOD Timer — parse success rate, latency by workout type, token usage, security",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "type": "row",
      "title": "AI Parse Pipeline",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "Parse Success Rate (1h)",
      "description": "Fraction of parse requests that succeeded in the last hour",
      "id": 2,
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none", "textMode": "auto" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": 0 }, { "color": "yellow", "value": 0.9 }, { "color": "green", "value": 0.99 }] },
          "mappings": []
        }
      },
      "targets": [
        {
          "datasource": { "uid": "grafanacloud-prom", "type": "prometheus" },
          "expr": "1 - (sum(rate(ai_parse_errors_total[1h])) / (sum(rate(ai_parse_requests_total[1h])) + 0.001))",
          "legendFormat": "success rate",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Workouts Parsed (24h)",
      "id": 3,
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "options": { "reduceOptions": { "calcs": ["sum"] }, "colorMode": "none", "graphMode": "none" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        {
          "datasource": { "uid": "grafanacloud-prom", "type": "prometheus" },
          "expr": "increase(workouts_parsed_total[24h])",
          "legendFormat": "{{workout_type}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Parse P95 Latency",
      "id": 4,
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": 0 }, { "color": "yellow", "value": 5 }, { "color": "red", "value": 10 }] }
        }
      },
      "targets": [
        {
          "datasource": { "uid": "grafanacloud-prom", "type": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(ai_parse_duration_seconds_bucket{stage='parse'}[1h])) by (le))",
          "legendFormat": "p95",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Parse Errors (1h)",
      "id": 5,
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "options": { "reduceOptions": { "calcs": ["sum"] }, "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": 0 }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 5 }] }
        }
      },
      "targets": [
        {
          "datasource": { "uid": "grafanacloud-prom", "type": "prometheus" },
          "expr": "sum(increase(ai_parse_errors_total[1h])) by (error_type)",
          "legendFormat": "{{error_type}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Parse Latency by Workout Type (p50 / p95)",
      "id": 6,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        {
          "datasource": { "uid": "grafanacloud-prom", "type": "prometheus" },
          "expr": "histogram_quantile(0.50, sum(rate(ai_parse_duration_seconds_bucket{stage='parse'}[5m])) by (le, workout_type))",
          "legendFormat": "p50 {{workout_type}}",
          "refId": "A"
        },
        {
          "datasource": { "uid": "grafanacloud-prom", "type": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(ai_parse_duration_seconds_bucket{stage='parse'}[5m])) by (le, workout_type))",
          "legendFormat": "p95 {{workout_type}}",
          "refId": "B"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Workouts Parsed per Minute by Type",
      "id": 7,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        {
          "datasource": { "uid": "grafanacloud-prom", "type": "prometheus" },
          "expr": "sum(rate(workouts_parsed_total[1m])) by (workout_type)",
          "legendFormat": "{{workout_type}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Parse Requests by Workout Type",
      "id": 8,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 13 },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        {
          "datasource": { "uid": "grafanacloud-prom", "type": "prometheus" },
          "expr": "sum(rate(ai_parse_requests_total[5m])) by (workout_type)",
          "legendFormat": "{{workout_type}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Parse Latency p95 Over Time",
      "id": 9,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 13 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        {
          "datasource": { "uid": "grafanacloud-prom", "type": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(ai_parse_duration_seconds_bucket{stage='parse'}[5m])) by (le, workout_type))",
          "legendFormat": "p95 {{workout_type}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "HTTP",
      "id": 30,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 21 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "HTTP Request Rate by Endpoint",
      "id": 31,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 22 },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        {
          "datasource": { "uid": "grafanacloud-prom", "type": "prometheus" },
          "expr": "sum(rate(http_server_duration_milliseconds_count[1m])) by (http_target, http_status_code)",
          "legendFormat": "{{http_target}} {{http_status_code}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP P95 Latency",
      "id": 32,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 22 },
      "fieldConfig": { "defaults": { "unit": "ms" } },
      "targets": [
        {
          "datasource": { "uid": "grafanacloud-prom", "type": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(http_server_duration_milliseconds_bucket[5m])) by (le, http_target))",
          "legendFormat": "p95 {{http_target}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Security",
      "id": 20,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 30 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Auth Failures per Minute",
      "id": 21,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 31 },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        {
          "datasource": { "uid": "grafanacloud-prom", "type": "prometheus" },
          "expr": "sum(rate(security_auth_failures_total[1m])) by (ip)",
          "legendFormat": "{{ip}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Auth Failures (24h)",
      "id": 22,
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 31 },
      "options": { "reduceOptions": { "calcs": ["sum"] }, "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": 0 }, { "color": "yellow", "value": 50 }, { "color": "red", "value": 200 }] }
        }
      },
      "targets": [
        {
          "datasource": { "uid": "grafanacloud-prom", "type": "prometheus" },
          "expr": "sum(increase(security_auth_failures_total[24h]))",
          "legendFormat": "failures",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["ai-wod-timer", "observability"],
  "templating": { "list": [] },
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "AI WOD Timer",
  "uid": "ai-wod-timer-main",
  "version": 1
}
